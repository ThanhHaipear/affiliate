{
  "name": "affiliate-marketplace-backend",
  "version": "1.0.0",
  "description": "REST API backend for affiliate marketing marketplace",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "node --test tests/*.test.js",
